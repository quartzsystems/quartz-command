# Quartz Command backend configuration.
# Loaded by quartz-command-backend.service; restart the service after editing:
#   systemctl restart quartz-command-backend

# Required. PostgreSQL connection string.
DATABASE_URL=postgres://quartz:CHANGE_ME@127.0.0.1/quartz_command

# Address the API binds to. A reverse proxy (or the packaged frontend's /api
# rewrite) fronts this; keep it on loopback unless you know otherwise.
QC_LISTEN=127.0.0.1:8080

# JWT signing secrets, generated on first start if the files don't exist.
QC_JWT_SECRET_FILE=/var/lib/quartz-command/jwt.secret
QC_ADMIN_JWT_SECRET_FILE=/var/lib/quartz-command/admin-jwt.secret

# Session cookies are Secure (HTTPS-only) by default. Set to false only for
# plain-HTTP testing.
QC_COOKIE_SECURE=true

# Session lifetime in hours (default 24).
#QC_SESSION_HOURS=24

# Optional default admin, seeded only while the admins table is empty.
#QC_DEFAULT_ADMIN_EMAIL=
#QC_DEFAULT_ADMIN_PASSWORD=
