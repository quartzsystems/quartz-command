# Quartz Command frontend (Next.js standalone server) configuration.
# Loaded by quartz-command-frontend.service; restart the service after editing:
#   systemctl restart quartz-command-frontend
#
# Note: the /api/* rewrite target (QC_API_URL) is baked in at build time and
# points at http://127.0.0.1:8080, matching the backend's default QC_LISTEN.

HOSTNAME=127.0.0.1
PORT=3000
