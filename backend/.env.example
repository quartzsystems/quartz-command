# Backend configuration. Copy to `.env` and adjust for your local PostgreSQL.
# The backend loads this file automatically on startup (no shell export needed).
# Only DATABASE_URL is strictly required.

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Point this at your own PostgreSQL server (run separately — not managed here).
# Create the role/database first, e.g.:
#   createdb quartz_command
#   psql -c "CREATE ROLE quartz LOGIN PASSWORD 'quartz'; GRANT ALL ON DATABASE quartz_command TO quartz;"
DATABASE_URL=postgres://quartz:quartz@localhost:5432/quartz_command

# ── Server ───────────────────────────────────────────────────────────────────
# Address axum binds to. The Next.js dev server proxies /api here.
QC_LISTEN=127.0.0.1:8080

# Set false for plain-HTTP local dev so the session cookies are sent without TLS.
QC_COOKIE_SECURE=false

# Session lifetime in hours.
QC_SESSION_HOURS=24

# Per-realm JWT signing secrets (auto-generated on first run if absent).
QC_JWT_SECRET_FILE=./data/jwt.secret
QC_ADMIN_JWT_SECRET_FILE=./data/admin-jwt.secret

# ── Device gateway (gRPC) ────────────────────────────────────────────────────
# Address the device gateway (enrollment + mTLS device services) binds to.
# Default is all interfaces — devices connect here directly, not via nginx.
#QC_GRPC_LISTEN=0.0.0.0:8443

# Public host:port devices reach the gateway at — embedded in enrollment
# tokens and returned as assigned_gateway. Defaults to QC_GRPC_LISTEN (dev
# only); set this to the real DNS name in any deployment. An admin-console
# override (Settings -> Server) takes precedence over this value.
#QC_GATEWAY_ADDR=gateway.example.com:8443

# Directory holding the internal device CA (key + cert, generated on first
# run). Device client certs are issued from this CA.
#QC_DEVICE_CA_DIR=./data/device-ca

# Gateway TLS server cert/key (PEM). Set both to serve a certificate of your
# own; leave unset and the gateway auto-issues one from the device CA at
# startup (devices verify it via the CA fingerprint in their enrollment
# token). A custom cert file must contain the full chain — devices match the
# token's CA fingerprint against the *presented* certificates (also set
# QC_GATEWAY_CA_FILE so tokens pin the right CA).
#QC_GRPC_TLS_CERT_FILE=
#QC_GRPC_TLS_KEY_FILE=

# Set to `off` for a plaintext dev listener instead of the auto-issued cert
# (enrollment works, mTLS device services are disabled).
#QC_GATEWAY_TLS=off

# Cert (PEM or DER) of the CA that issued the gateway's TLS cert; its SHA-256
# goes into enrollment tokens. Defaults to the device CA cert.
#QC_GATEWAY_CA_FILE=

# ── Default admin ────────────────────────────────────────────────────────────
# Seeded on startup ONLY when the `admins` table is empty. Use it to get into
# /admin/login on a fresh database, then change the password. Leave unset to
# skip. CHANGE THESE before any real deployment.
QC_DEFAULT_ADMIN_EMAIL=admin@quartz.systems
QC_DEFAULT_ADMIN_PASSWORD=changeme
