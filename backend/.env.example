# Backend configuration. Copy to `.env` and adjust for your local PostgreSQL.
# The backend loads this file automatically on startup (no shell export needed).
# Only DATABASE_URL is strictly required.

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Point this at your own PostgreSQL server (run separately — not managed here).
# Create the role/database first, e.g.:
#   createdb quartz_command
#   psql -c "CREATE ROLE quartz LOGIN PASSWORD 'quartz'; GRANT ALL ON DATABASE quartz_command TO quartz;"
DATABASE_URL=postgres://quartz:quartz@localhost:5432/quartz_command

# ── Server ───────────────────────────────────────────────────────────────────
# Address axum binds to. The Next.js dev server proxies /api here.
QC_LISTEN=127.0.0.1:8080

# Set false for plain-HTTP local dev so the session cookies are sent without TLS.
QC_COOKIE_SECURE=false

# Session lifetime in hours.
QC_SESSION_HOURS=24

# Per-realm JWT signing secrets (auto-generated on first run if absent).
QC_JWT_SECRET_FILE=./data/jwt.secret
QC_ADMIN_JWT_SECRET_FILE=./data/admin-jwt.secret

# ── Default admin ────────────────────────────────────────────────────────────
# Seeded on startup ONLY when the `admins` table is empty. Use it to get into
# /admin/login on a fresh database, then change the password. Leave unset to
# skip. CHANGE THESE before any real deployment.
QC_DEFAULT_ADMIN_EMAIL=admin@quartz.systems
QC_DEFAULT_ADMIN_PASSWORD=changeme
